        "jsCode": "// Strip markdown code blocks if present\nconst raw = $input.first().json.choices[0].message.content\n  .replace(/^```json\\n?/, '')\n  .replace(/^```\\n?/, '')\n  .replace(/```$/, '')\n  .trim();\n\n// Remove control characters before parsing\nconst cleaned = raw.replace(/[\\x00-\\x1F\\x7F]/g, (char) => {\n  if (char === '\\n') return '\\\\n';\n  if (char === '\\r') return '\\\\r';\n  if (char === '\\t') return '\\\\t';\n  return '';\n});\n\nconst parsed = JSON.parse(cleaned);\n\nreturn {\n  score: parsed.score,\n  coverLetter: parsed.coverLetter\n};"
      },
